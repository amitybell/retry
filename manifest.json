{
  "manifest_version": 2,
  "name": "ReTry",
  "homepage_url": "https://github.com/amitybell/retry",
  "version": "0.2.0",
  "description": "Automatically reload the page on 403 (Forbidden) and 429 (Rate limited) errors",
  "icons": {
    "32": "icons/icon.svg",
    "64": "icons/icon.svg"
  },
  "permissions": [
    "webRequest",
    "storage",
    "<all_urls>"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "@retry.amitybell.com",
      "data_collection_permissions": {
        "required": ["none"]
      },
      "strict_min_version": "140.0"
    }
  },
  "browser_action": {
    "default_title": "ReTry",
    "default_icon": "icons/icon.svg"
  },
  "page_action": {
    "default_icon": {
      "19": "icons/icon.svg",
      "38": "icons/icon.svg"
    }
  },
  "background": {
    "scripts": ["background.js"]
  }
}
